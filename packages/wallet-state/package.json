{
  "name": "@unisat/wallet-state",
  "version": "1.0.0",
  "description": "Redux state management for UniSat wallet, shared between platforms",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "build:cjs": "tsup --format cjs",
    "build:esm": "tsup --format esm", 
    "build:typed": "tsc --declaration --declarationMap --emitDeclarationOnly --outDir lib",
    "test": "vitest",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": "^1.9.0",
    "react": "^18.0.0",
    "react-redux": "^8.0.0",
    "@unisat/wallet-types": "1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "eslint": "^8.0.0",
    "tsup": "^7.0.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "publishConfig": {
    "access": "public"
  }
}