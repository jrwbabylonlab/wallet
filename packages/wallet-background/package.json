{
  "name": "@unisat/wallet-background",
  "version": "1.0.0",
  "description": "Complete wallet background logic for UniSat wallet, cross-platform compatible",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "build:cjs": "tsup --format cjs",
    "build:esm": "tsup --format esm",
    "build:typed": "tsc --declaration --declarationMap --emitDeclarationOnly --outDir lib",
    "test": "vitest",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@unisat/keyring-service": "workspace:*",
    "@unisat/permission-service": "workspace:*",
    "@unisat/wallet-types": "workspace:*",
    "@unisat/tx-helpers": "workspace:*",
    "@unisat/wallet-api": "workspace:*",
    "@unisat/wallet-bitcoin": "workspace:*",
    "@unisat/babylon-service": "workspace:*",
    "@unisat/contact-book": "workspace:*",
    "@unisat/i18n": "workspace:*"
  },
  "dependencies": {
    "bignumber.js": "^9.1.1",
    "eventemitter3": "^5.0.1",
    "koa-compose": "^4.1.0",
    "debounce": "^1.2.1",
    "randomstring": "^1.2.3",
    "compare-versions": "^4.1.3",
    "lodash-es": "^4.17.21",
    "lodash": "^4.17.21",
    "bitcore-lib": "^10.0.0",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "tsup": "^7.0.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
